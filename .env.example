# System Configuration
PGID=1000
PUID=1000
TZ=Europe/London

# Docker Compose Profiles
# Customize based on your OS and needs
# macOS: COMPOSE_PROFILES=admin,downloads,iot,media,proxy
# Linux: COMPOSE_PROFILES=admin,downloads,iot,media,media-hwa,proxy
COMPOSE_PROFILES=admin,downloads,iot,media,media-hwa,proxy

# Directory Paths
CACHE_DIR=./cache
CONFIG_DIR=./config
DATA_DIR=./data
DOWNLOADS_DIR=./downloads
MEDIA_DIR=./media

# Version Control
BAZARR_VERSION=latest
BUILDARR_VERSION=latest
CADDY_VERSION=latest
CLOUDFLARED_VERSION=latest
GLUETUN_VERSION=latest
HOMARR_VERSION=latest
HOMEASSISTANT_VERSION=latest
JELLYFIN_VERSION=latest
JELLYSEERR_VERSION=latest
LIDARR_VERSION=latest
PIHOLE_VERSION=latest
PORTAINER_VERSION=latest
PROWLARR_VERSION=latest
QBITTORRENT_VERSION=latest
RADARR_VERSION=latest
SONARR_VERSION=latest

# Authentication & Secrets
CLOUDFLARE_TUNNEL_TOKEN=changeme
PIHOLE_WEBSERVER_API_PASSWORD=changeme

# WireGuard Private Key for NordVPN
# To obtain your WireGuard private key:
# 1. Get an access token from the NordVPN dashboard: https://my.nordaccount.com/dashboard/nordvpn/
# 2. Run the following command (replace <ACCESS_TOKEN> with your token):
#    curl -s -u token:<ACCESS_TOKEN> https://api.nordvpn.com/v1/users/services/credentials
# 3. Copy the "nordlynx_private_key" value from the response
WIREGUARD_PRIVATE_KEY=changeme

# Network & VPN Configuration
SERVER_COUNTRIES="United Kingdom"
