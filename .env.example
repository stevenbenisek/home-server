# Docker Compose Files
# Customize based on your OS and needs
COMPOSE_FILE=services/home-automation/docker-compose.yml:services/media-automation/docker-compose.yml:services/media-playback/docker-compose.linux.yml:services/network-management/docker-compose.yml:services/system-monitoring/docker-compose.yml

# Docker Compose Profiles
# Customize based on your OS and needs
# macOS: COMPOSE_PROFILES=
#   - Docker on macOS lacks GPU passthrough for hardware transcoding. Run Jellyfin natively instead.
#   - Docker on macOS lacks USB passthrough for Zigbee/Thread and ESPHome. Run ESPHome natively instead.
# Linux: COMPOSE_PROFILES=gpu-passthrough,usb-passthrough
COMPOSE_PROFILES=gpu-passthrough,usb-passthrough

# System Configuration
PGID=1000
PUID=1000
TZ=Europe/London

# Directory Paths
DOWNLOADS_DIR=./volumes/downloads
MEDIA_DIR=./volumes/media

# Version Control
BAZARR_TAG=latest
CADDY_TAG=latest
ESPHOME_TAG=latest
GLUETUN_TAG=latest
HOMARR_TAG=latest
HOMEASSISTANT_TAG=latest
JELLYFIN_TAG=latest
JELLYSEERR_TAG=latest
LIDARR_TAG=latest
PIHOLE_TAG=latest
PORTAINER_TAG=latest
PROWLARR_TAG=latest
QBITTORRENT_TAG=latest
RADARR_TAG=latest
SONARR_TAG=latest

# ESPHome Config
ESPHOME_PASSWORD=changeme
ESPHOME_USERNAME=changeme

# Gluetun Config
SERVER_COUNTRIES="United Kingdom"
# WireGuard Private Key for NordVPN
# To obtain your WireGuard private key:
# 1. Get an access token from the NordVPN dashboard: https://my.nordaccount.com/dashboard/nordvpn/
# 2. Run the following command (replace <ACCESS_TOKEN> with your token):
#    curl -s -u token:<ACCESS_TOKEN> https://api.nordvpn.com/v1/users/services/credentials
# 3. Copy the "nordlynx_private_key" value from the response
WIREGUARD_PRIVATE_KEY=changeme

# Pihole Config
WEBSERVER_API_PASSWORD=changeme
